{
  "name": "cc-mission-control",
  "version": "0.1.0",
  "description": "A mission-control dashboard for Claude Code sessions running in WezTerm — live terminal thumbnails, status at a glance, click to focus.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "node --run build:client && tsx watch src/server.ts",
    "start": "node --run build:client && tsx src/server.ts",
    "build:client": "esbuild src/client/main.ts --bundle --format=esm --outfile=public/app.js",
    "watch:client": "esbuild src/client/main.ts --bundle --format=esm --outfile=public/app.js --watch",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
